WA_TRIGGER=@govorun
WA_DM_ALWAYS_RESPOND=true
WA_GROUP_TRIGGER_REQUIRED=true
WA_ALLOWED_GROUPS=
WA_ALLOWED_DMS=
WA_STATE_DIR=/home/wa-govorun/whatsapp-govorun/state
WA_AUTH_DIR=/home/wa-govorun/whatsapp-govorun/state/auth
WA_LOGS_DIR=/home/wa-govorun/whatsapp-govorun/state/logs
WA_RESPONSE_MAX_CHARS=3500
# Optional: set digits-only phone to use pairing-code fallback instead of QR
WA_PAIRING_PHONE=
# Optional custom 8-char pairing code (leave blank to auto-generate)
WA_PAIRING_CODE=
CODEX_WORKDIR=/home/architect/matrix
CODEX_MODEL=gpt-5-codex-mini
CODEX_REASONING_EFFORT=medium
CODEX_FULL_ACCESS=true
CODEX_BIN=/usr/local/bin/codex
CODEX_TIMEOUT_MS=240000
LOG_LEVEL=info
