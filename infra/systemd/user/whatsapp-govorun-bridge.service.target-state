[Unit]
Description=WhatsApp Govorun Bridge (Codex)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/wa-govorun/whatsapp-govorun/app
Environment=HOME=/home/wa-govorun
ExecStart=/usr/bin/node /home/wa-govorun/whatsapp-govorun/app/src/index.mjs
Restart=always
RestartSec=3
StandardOutput=append:/home/wa-govorun/whatsapp-govorun/state/logs/service.log
StandardError=append:/home/wa-govorun/whatsapp-govorun/state/logs/service.err.log

[Install]
WantedBy=default.target
