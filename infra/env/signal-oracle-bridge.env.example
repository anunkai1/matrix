# Copy to /etc/default/signal-oracle-bridge and set real values.
SIGNAL_ACCOUNT=+15551234567
# Optional when filtering own messages across linked devices.
# SIGNAL_ACCOUNT_UUID=
SIGNAL_CLI_PATH=signal-cli
SIGNAL_HTTP_HOST=127.0.0.1
SIGNAL_HTTP_PORT=8080
SIGNAL_RECEIVE_MODE=manual
SIGNAL_IGNORE_ATTACHMENTS=false
SIGNAL_IGNORE_STORIES=true
SIGNAL_SEND_READ_RECEIPTS=false
SIGNAL_STATE_DIR=/home/oracle/signal-oracle/state
SIGNAL_API_HOST=127.0.0.1
SIGNAL_API_PORT=8797
# SIGNAL_API_AUTH_TOKEN=replace_me
SIGNAL_API_MAX_UPDATES_PER_POLL=100
SIGNAL_API_MAX_QUEUE_SIZE=2000
SIGNAL_API_MAX_LONG_POLL_SECONDS=30
SIGNAL_FILE_MAX_BYTES=52428800
SIGNAL_FILE_MAX_TOTAL_BYTES=524288000
SIGNAL_DAEMON_STARTUP_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
