# Copy to /etc/default/server3-browser-brain and set real values.

BROWSER_BRAIN_HOST=127.0.0.1
BROWSER_BRAIN_PORT=47831
BROWSER_BRAIN_BROWSER_EXECUTABLE=/usr/bin/brave-browser
BROWSER_BRAIN_STATE_DIR=/var/lib/server3-browser-brain
BROWSER_BRAIN_PROFILE_DIR=/var/lib/server3-browser-brain/profile
BROWSER_BRAIN_CAPTURE_DIR=/var/lib/server3-browser-brain/captures
BROWSER_BRAIN_REMOTE_DEBUGGING_PORT=9223
BROWSER_BRAIN_STARTUP_TIMEOUT_SECONDS=20
BROWSER_BRAIN_ACTION_TIMEOUT_MS=7000
BROWSER_BRAIN_SCREENSHOT_TTL_HOURS=24
BROWSER_BRAIN_HEADLESS=true
BROWSER_BRAIN_LOG_ACTIONS=true
