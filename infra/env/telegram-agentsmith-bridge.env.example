# Copy to /etc/default/telegram-agentsmith-bridge and set real values.
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ASSISTANT_NAME=AgentSmith
TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false
TELEGRAM_PERSISTENT_WORKERS_ENABLED=false
TELEGRAM_CANONICAL_SESSIONS_ENABLED=false
TELEGRAM_RESTART_SCRIPT=/home/architect/matrix/ops/telegram-bridge/restart_and_verify.sh
TELEGRAM_RESTART_UNIT=telegram-agentsmith-bridge.service

# Optional bridge paths:
# TELEGRAM_BRIDGE_STATE_DIR=/home/agentsmith/.local/state/telegram-agentsmith-bridge
# TELEGRAM_LOG_LEVEL=INFO
# TELEGRAM_API_BASE=https://api.telegram.org
# TELEGRAM_EXEC_TIMEOUT_SECONDS=36000
# TELEGRAM_MAX_INPUT_CHARS=4096
# TELEGRAM_MAX_OUTPUT_CHARS=20000
# TELEGRAM_MAX_IMAGE_BYTES=10485760
# TELEGRAM_MAX_VOICE_BYTES=20971520
# TELEGRAM_MAX_DOCUMENT_BYTES=52428800
# TELEGRAM_RATE_LIMIT_PER_MINUTE=12
# TELEGRAM_POLICY_WATCH_FILES=/home/agentsmith/agentsmithbot/AGENTS.md

# Optional selectable engine support:
# TELEGRAM_SELECTABLE_ENGINE_PLUGINS=codex,gemma,pi,venice
# PI_RUNNER=local
# PI_LOCAL_CWD=/home/agentsmith/agentsmithbot
# PI_SESSION_MODE=telegram_scope
# PI_SESSION_MAX_BYTES=2097152
# PI_SESSION_MAX_AGE_SECONDS=604800
# PI_SESSION_ARCHIVE_RETENTION_SECONDS=1209600
# PI_SESSION_ARCHIVE_DIR=
# PI_OLLAMA_TUNNEL_ENABLED=false
# PI_OLLAMA_TUNNEL_LOCAL_PORT=11436
# PI_OLLAMA_TUNNEL_REMOTE_HOST=127.0.0.1
# PI_OLLAMA_TUNNEL_REMOTE_PORT=11434
# VENICE_API_KEY=replace_me
# VENICE_BASE_URL=https://api.venice.ai/api/v1
# VENICE_MODEL=deepseek-v4-flash
# VENICE_TEMPERATURE=0.2
# VENICE_REQUEST_TIMEOUT_SECONDS=180
