# Redacted mirror of selected live /etc/default/telegram-sentinel-bridge values on Server3.
# Source path: /etc/default/telegram-sentinel-bridge
# Secrets are intentionally redacted and must never be committed.

TELEGRAM_BOT_TOKEN=<redacted>
TELEGRAM_ALLOWED_CHAT_IDS=211761499,-1003706836145
TELEGRAM_ASSISTANT_NAME=Sentinel
TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false
TELEGRAM_PERSISTENT_WORKERS_ENABLED=true
TELEGRAM_PERSISTENT_WORKERS_MAX=10
TELEGRAM_PERSISTENT_WORKERS_IDLE_TIMEOUT_SECONDS=18000
TELEGRAM_CANONICAL_SESSIONS_ENABLED=true
TELEGRAM_CANONICAL_SQLITE_ENABLED=true
TELEGRAM_CANONICAL_LEGACY_MIRROR_ENABLED=false
TELEGRAM_CANONICAL_JSON_MIRROR_ENABLED=false
TELEGRAM_BRIDGE_STATE_DIR=/var/lib/sentinelbot
TELEGRAM_CANONICAL_SQLITE_PATH=/var/lib/sentinelbot/chat_sessions.sqlite3
TELEGRAM_MEMORY_SQLITE_PATH=/var/lib/sentinelbot/memory.sqlite3
TELEGRAM_CODEX_WORKDIR=/home/architect/matrix
TELEGRAM_POLICY_WATCH_MODE=none
TELEGRAM_RESTART_SCRIPT=/home/architect/matrix/ops/telegram-bridge/restart_and_verify.sh
TELEGRAM_RESTART_UNIT=telegram-sentinel-bridge.service
TELEGRAM_SELECTABLE_ENGINE_PLUGINS=codex,gemma,pi
PI_RUNNER=local
PI_LOCAL_CWD=/home/sentinel/sentinelbot
PI_REQUEST_TIMEOUT_SECONDS=600
PI_SESSION_MODE=telegram_scope
PI_SESSION_DIR=
PI_OLLAMA_TUNNEL_ENABLED=false
PI_OLLAMA_TUNNEL_LOCAL_PORT=11438
PI_OLLAMA_TUNNEL_REMOTE_HOST=127.0.0.1
PI_OLLAMA_TUNNEL_REMOTE_PORT=11434
PI_PROVIDER=venice
PI_MODEL=deepseek-v4-flash
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=deepseek-v4-flash
VENICE_TEMPERATURE=0.2
VENICE_REQUEST_TIMEOUT_SECONDS=180
