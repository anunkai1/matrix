# Copy to /etc/default/govorun-whatsapp-daily-uplift
WA_DAILY_UPLIFT_API_BASE=http://127.0.0.1:8787
# Optional bearer auth for bridge API if enabled.
# WA_DAILY_UPLIFT_AUTH_TOKEN=
WA_DAILY_UPLIFT_TZ=Australia/Brisbane
WA_DAILY_UPLIFT_GROUP_NAME=Путиловы
# Local state, sent-history, and Reddit cache.
WA_DAILY_UPLIFT_STATE_DIR=/home/govorun/.local/state/govorun-whatsapp-daily-uplift
# Optional override for the combined SQLite path.
# WA_DAILY_UPLIFT_DB_PATH=/home/govorun/.local/state/govorun-whatsapp-daily-uplift/daily_uplift.sqlite3
# Backward-compatible legacy alias if needed.
# WA_DAILY_UPLIFT_HISTORY_DB_PATH=/home/govorun/.local/state/govorun-whatsapp-daily-uplift/daily_uplift.sqlite3
# Local Reddit cache tuning (`r/LifeProTips` top posts from the last 5 years).
# WA_DAILY_UPLIFT_REDDIT_CACHE_MAX_AGE_SECONDS=604800
# WA_DAILY_UPLIFT_REDDIT_MIN_UNUSED=30
# WA_DAILY_UPLIFT_REDDIT_FETCH_PAGES=10
# WA_DAILY_UPLIFT_REDDIT_FETCH_PAGE_SIZE=100
# WA_DAILY_UPLIFT_REDDIT_LOOKBACK_DAYS=1825
# WA_DAILY_UPLIFT_REDDIT_USER_AGENT=matrix-govorun-daily-uplift/1.0
# Optional additional Reddit search paths merged into the cache (`||`-separated).
# WA_DAILY_UPLIFT_REDDIT_SEARCH_QUERIES=tip OR tips||work OR job OR career||money OR save OR budget
# Optional Codex tuning for adapting cached Reddit ideas into Russian.
# WA_DAILY_UPLIFT_CODEX_BIN=codex
# WA_DAILY_UPLIFT_CODEX_MODEL=gpt-5-codex-mini
# WA_DAILY_UPLIFT_CODEX_REASONING_EFFORT=medium
# WA_DAILY_UPLIFT_CODEX_TIMEOUT_SECONDS=180
# WA_DAILY_UPLIFT_SOURCE_SELECTION_ATTEMPTS=12
# Preferred destination for scheduled group send.
WA_DAILY_UPLIFT_CHAT_JID=61423665514-1534056215@g.us
# Optional fallback numeric destination.
# WA_DAILY_UPLIFT_CHAT_ID=
