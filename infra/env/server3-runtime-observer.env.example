# Server3 Runtime Observer (Phase 1, day-1 collect-only)

# Timezone for rendered status timestamps.
RUNTIME_OBSERVER_TZ=Australia/Brisbane

# Snapshot store path (used by collect/status/summary commands).
RUNTIME_OBSERVER_STATE_DIR=/var/lib/server3-runtime-observer

# Keep this as collect_only in Phase 1.
RUNTIME_OBSERVER_MODE=collect_only

# Retention for local snapshot history (hours).
RUNTIME_OBSERVER_RETENTION_HOURS=168

# WhatsApp runtime log file used for reconnect KPI extraction.
RUNTIME_OBSERVER_WA_LOG_PATH=/home/govorun/whatsapp-govorun/state/logs/service.log
