# Server3 Runtime Observer

# Timezone for rendered status timestamps.
RUNTIME_OBSERVER_TZ=Australia/Brisbane

# Snapshot store path (used by collect/status/summary commands).
RUNTIME_OBSERVER_STATE_DIR=/var/lib/server3-runtime-observer

# Runtime mode:
# - collect_only: snapshots/status only (no notifications)
# - telegram_alerts: send proactive alerts + recovery messages to Telegram
# - telegram_daily_summary: send scheduled daily Telegram summary only
# - telegram_alerts_daily: send both proactive alerts and daily summary
RUNTIME_OBSERVER_MODE=collect_only

# Retention for local snapshot history (hours).
RUNTIME_OBSERVER_RETENTION_HOURS=168

# WhatsApp runtime log file used for reconnect KPI extraction.
RUNTIME_OBSERVER_WA_LOG_PATH=/home/govorun/whatsapp-govorun/state/logs/service.log

# Alert reminder cooldown when an incident stays active (minutes).
RUNTIME_OBSERVER_ALERT_COOLDOWN_MINUTES=30

# Telegram send timeout for alert delivery (seconds).
RUNTIME_OBSERVER_ALERT_TIMEOUT_SECONDS=10

# Optional explicit Telegram routing (comma-separated chat IDs).
# If omitted, observer falls back to TELEGRAM_ALLOWED_CHAT_IDS from
# /etc/default/telegram-architect-bridge.
# RUNTIME_OBSERVER_TELEGRAM_CHAT_IDS=123456789

# Optional explicit bot token override.
# If omitted, observer falls back to TELEGRAM_BOT_TOKEN from
# /etc/default/telegram-architect-bridge.
# RUNTIME_OBSERVER_TELEGRAM_BOT_TOKEN=123456:replace_me
