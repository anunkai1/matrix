# Home Assistant ops credentials for scripts under ops/ha.
# Copy to /etc/default/ha-ops on Server3 and set real values.

HA_BASE_URL=http://home-assistant.local:8123
HA_TOKEN=replace-with-long-lived-access-token

# Optional compatibility aliases (scripts already read both names)
TELEGRAM_HA_BASE_URL=${HA_BASE_URL}
TELEGRAM_HA_TOKEN=${HA_TOKEN}
