# Architect Google OAuth environment template.
# Keep secret files outside git. These paths are local-only.

GOOGLE_ACCOUNT_EMAIL=vladislavsllm26@gmail.com
GOOGLE_OAUTH_CLIENT_SECRET_PATH=/home/architect/.config/google/architect/client_secret.json
GOOGLE_OAUTH_TOKEN_PATH=/home/architect/.config/google/architect/oauth_token.json
# Scopes are space-delimited for device-flow requests.
GOOGLE_OAUTH_SCOPES=https://mail.google.com/ https://www.googleapis.com/auth/calendar
