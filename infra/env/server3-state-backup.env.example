SERVER3_STATE_BACKUP_ROOT=/srv/external/server3-backups/state
SERVER3_STATE_BACKUP_RETENTION_COUNT=3
SERVER3_STATE_BACKUP_HOSTNAME=server3
SERVER3_STATE_BACKUP_REPO_PATH=/home/architect/matrix
SERVER3_STATE_BACKUP_FAIL_ON_MISSING=yes
SERVER3_STATE_BACKUP_STOP_UNITS=(
  telegram-architect-bridge.service
  telegram-diary-bridge.service
  telegram-tank-bridge.service
  telegram-trinity-bridge.service
  telegram-macrorayd-bridge.service
  whatsapp-govorun-bridge.service
  govorun-whatsapp-bridge.service
  signal-oracle-bridge.service
  oracle-signal-bridge.service
  media-stack.service
  server3-monitoring.service
)
SERVER3_STATE_BACKUP_INCLUDE_PATHS=(
  /etc/apt/sources.list.d
  /etc/cron.d
  /etc/default
  /etc/fstab
  /etc/sudoers.d
  /etc/systemd/system
  /home/architect/.codex
  /home/architect/.local/state
  /home/diary/.codex
  /home/diary/.local/state
  /home/diary/diarybot
  /home/govorun/.codex
  /home/govorun/.local/state
  /home/govorun/govorunbot
  /home/govorun/whatsapp-govorun/app
  /home/govorun/whatsapp-govorun/state
  /home/macrorayd/.codex
  /home/macrorayd/.local/state
  /home/macrorayd/macroraydbot
  /home/oracle/.codex
  /home/oracle/.local/state
  /home/oracle/oraclebot
  /home/oracle/signal-oracle/app
  /home/oracle/signal-oracle/state
  /home/tank/.codex
  /home/tank/.local/state
  /home/tank/tankbot
  /home/trinity/.codex
  /home/trinity/trinitybot
  /srv/media-stack/config
  /srv/media-stack/docker-compose.yml
  /srv/server3-monitoring
  /usr/share/keyrings/tailscale-archive-keyring.gpg
  /var/lib/nordvpn
  /var/lib/trinitybot
  /var/lib/tailscale
)
SERVER3_STATE_BACKUP_EXCLUDE_PATTERNS=(
  "/srv/external/server3-arr"
  "/srv/media-stack/downloads"
  "/srv/media-stack/downloads.internal_legacy_20260313-205441"
  "/srv/media-stack/media"
  "/srv/server3-monitoring/data/prometheus"
  "*/.cache/*"
  "*/ipc-socket"
  "*/lockfile"
  "*/logs/*"
  "*/log/*"
  "*/shell_snapshots/*"
  "*/tmp/*"
  "*.lock"
  "*.pid"
  "*.sock"
)
