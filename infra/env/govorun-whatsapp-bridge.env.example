# Copy to /etc/default/govorun-whatsapp-bridge and set real values.
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=1434663945
TELEGRAM_EXEC_TIMEOUT_SECONDS=36000
TELEGRAM_MAX_INPUT_CHARS=4096
TELEGRAM_MAX_OUTPUT_CHARS=20000
TELEGRAM_RATE_LIMIT_PER_MINUTE=12
TELEGRAM_LOG_LEVEL=INFO
TELEGRAM_CHANNEL_PLUGIN=whatsapp
TELEGRAM_ENGINE_PLUGIN=codex
# Optional response style/language guide injected ahead of each prompt.
# Example English-default policy for Govorun only:
# TELEGRAM_RESPONSE_STYLE_HINT=Default to English. Reply in English unless the user clearly uses another language or asks for a different one. Keep replies useful first, concise by default, and lightly playful only when it fits.
# Optional Codex runtime args for speed/profile tuning (applies to new and resumed chats):
# ARCHITECT_EXEC_ARGS="--model gpt-5-codex-mini --config model_reasoning_effort=\"medium\""
# Optional compact progress wording for WhatsApp:
# TELEGRAM_PROGRESS_LABEL=Govorun is thinking
# TELEGRAM_PROGRESS_ELAPSED_PREFIX=Already
# TELEGRAM_PROGRESS_ELAPSED_SUFFIX=s
# Optional busy-lock message shown when a previous prompt is still running:
# TELEGRAM_BUSY_MESSAGE="Quick note: I am still busy with the previous request. I will be back soon."
# Optional memory reset when watched policy files change.
# Useful for Govorun when you want `/home/govorun/govorunbot/AGENTS.md` changes
# to take effect without old bridge memory carrying forward stale context.
# TELEGRAM_POLICY_RESET_MEMORY_ON_CHANGE=true
WHATSAPP_PLUGIN_ENABLED=true
WHATSAPP_BRIDGE_API_BASE=http://127.0.0.1:8787
WHATSAPP_POLL_TIMEOUT_SECONDS=20
# Prefix policy for inbound prompts:
# TELEGRAM_REQUIRED_PREFIXES=@говорун,говорун,govorun
# TELEGRAM_REQUIRED_PREFIX_IGNORE_CASE=true
# Set false to allow 1:1/private chats without summon prefix.
# TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false
# Set true to allow private chats even when TELEGRAM_ALLOWED_CHAT_IDS does not contain the DM chat id.
# TELEGRAM_ALLOW_PRIVATE_CHATS_UNLISTED=true
# Enable voice-note transcription for WhatsApp voice messages.
# TELEGRAM_VOICE_TRANSCRIBE_CMD=/home/architect/matrix/ops/telegram-voice/transcribe_voice.sh {file}
# TELEGRAM_VOICE_TRANSCRIBE_TIMEOUT_SECONDS=180
# TELEGRAM_VOICE_LOW_CONFIDENCE_THRESHOLD=0.35
# TELEGRAM_VOICE_LOW_CONFIDENCE_MESSAGE="I could not understand that voice note clearly. Please say it again."
# TELEGRAM_VOICE_WHISPER_VENV=/home/govorun/.local/share/telegram-voice/venv
# TELEGRAM_VOICE_WHISPER_SOCKET_PATH=/tmp/govorun-voice-whisper.sock
# TELEGRAM_VOICE_WHISPER_LOG_PATH=/tmp/govorun-voice-whisper.log
# TELEGRAM_VOICE_WHISPER_LANGUAGE=ru
# HF_HOME=/home/govorun/.cache/huggingface
# TELEGRAM_VOICE_WHISPER_MODEL=medium
TELEGRAM_BRIDGE_STATE_DIR=/home/govorun/.local/state/govorun-whatsapp-bridge
# Watch Govorun's live persona/policy file and reset stored chat threads when it changes.
TELEGRAM_POLICY_WATCH_FILES=/home/govorun/govorunbot/AGENTS.md
TELEGRAM_CANONICAL_SESSIONS_ENABLED=true
TELEGRAM_CANONICAL_LEGACY_MIRROR_ENABLED=false
TELEGRAM_CANONICAL_SQLITE_ENABLED=true
TELEGRAM_CANONICAL_SQLITE_PATH=/home/govorun/.local/state/govorun-whatsapp-bridge/chat_sessions.sqlite3
TELEGRAM_CANONICAL_JSON_MIRROR_ENABLED=false
TELEGRAM_MEMORY_SQLITE_PATH=/home/govorun/.local/state/govorun-whatsapp-bridge/memory.sqlite3
TELEGRAM_MEMORY_MAX_MESSAGES_PER_KEY=4000
TELEGRAM_MEMORY_MAX_SUMMARIES_PER_KEY=80
TELEGRAM_MEMORY_PRUNE_INTERVAL_SECONDS=300
# Optional attachment archive for replied photos/files.
# Default retention is 14 days and default cap is 10 GiB if unset.
# TELEGRAM_ATTACHMENT_RETENTION_SECONDS=1209600
# TELEGRAM_ATTACHMENT_MAX_TOTAL_BYTES=10737418240
