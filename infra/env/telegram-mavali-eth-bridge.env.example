# Copy to /etc/default/telegram-mavali-eth-bridge and set real values.
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ASSISTANT_NAME=Mavali ETH
TELEGRAM_ENGINE_PLUGIN=mavali_eth
TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false
TELEGRAM_PERSISTENT_WORKERS_ENABLED=false
TELEGRAM_CANONICAL_SESSIONS_ENABLED=false

# Optional bridge paths:
# TELEGRAM_BRIDGE_STATE_DIR=/home/mavali_eth/.local/state/telegram-mavali-eth-bridge
# TELEGRAM_LOG_LEVEL=INFO
# TELEGRAM_API_BASE=https://api.telegram.org

# Mavali ETH runtime:
MAVALI_ETH_TELEGRAM_OWNER_CHAT_ID=123456789
MAVALI_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/replace_me
MAVALI_ETH_KEYSTORE_PASSPHRASE=replace_me
MAVALI_ETH_MAX_FEE_PER_GAS_GWEI=5
MAVALI_ETH_CONFIRMATION_COUNT=2
MAVALI_ETH_PENDING_ACTION_EXPIRY_MINUTES=10
MAVALI_ETH_POLLING_INTERVAL_MINUTES=30

# Signing helper runtime:
# MAVALI_ETH_VENV=/home/mavali_eth/.local/share/mavali-eth/venv
# MAVALI_ETH_PYTHON_BIN=/home/mavali_eth/.local/share/mavali-eth/venv/bin/python3
# MAVALI_ETH_SIGNER_HELPER_SCRIPT=/home/architect/matrix/ops/mavali_eth/eth_account_helper.py
# MAVALI_ETH_DB_PATH=/home/mavali_eth/.local/state/telegram-mavali-eth-bridge/mavali_eth.sqlite3
# MAVALI_ETH_KEYSTORE_PATH=/home/mavali_eth/.local/state/telegram-mavali-eth-bridge/wallet.json

