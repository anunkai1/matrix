# Mirror template for /home/govorun/whatsapp-govorun/app/.env
WA_TRIGGER=@говорун
WA_ALLOW_FROM_ME_GROUP_TRIGGER_ONLY=true
WA_DM_ALWAYS_RESPOND=true
WA_GROUP_TRIGGER_REQUIRED=true
# Group-only numeric allowlist for plugin-mode ingress.
# DMs are controlled by WA_ALLOWED_DMS and WA_DM_ALWAYS_RESPOND.
WA_ALLOWED_CHAT_IDS=
WA_ALLOWED_GROUPS=
WA_ALLOWED_DMS=
WA_STATE_DIR=/home/govorun/whatsapp-govorun/state
WA_AUTH_DIR=/home/govorun/whatsapp-govorun/state/auth
WA_LOGS_DIR=/home/govorun/whatsapp-govorun/state/logs
WA_RESPONSE_MAX_CHARS=3500
WA_PAIRING_PHONE=
WA_PAIRING_CODE=
WA_PLUGIN_MODE=true
WA_API_HOST=127.0.0.1
WA_API_PORT=8787
WA_API_MAX_UPDATES_PER_POLL=100
WA_API_MAX_QUEUE_SIZE=2000
WA_API_MAX_LONG_POLL_SECONDS=30
WA_FILE_MAX_BYTES=52428800
CODEX_WORKDIR=/home/architect/matrix
CODEX_MODEL=gpt-5-codex-mini
CODEX_REASONING_EFFORT=medium
CODEX_FULL_ACCESS=true
CODEX_BIN=/usr/local/bin/codex
CODEX_TIMEOUT_MS=240000
LOG_LEVEL=info
