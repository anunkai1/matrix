# Copy to /etc/default/signaltube-lab

# Optional bootstrap topic list used by scheduled-collect in addition to DB topics.
# Separate topics with || so spaces can stay unescaped.
SIGNALTUBE_LAB_TOPICS=latest space videos||LLM research

# Local state paths.
SIGNALTUBE_LAB_DB_PATH=/home/architect/matrix/private/signaltube/signaltube.sqlite
SIGNALTUBE_LAB_HTML_PATH=/home/architect/matrix/private/signaltube/feed.html

# Disposable Browser Brain endpoint managed by ops/signaltube_lab_browser.sh.
SIGNALTUBE_LAB_BROWSER_BRAIN_URL=http://127.0.0.1:47832

# Rendered feed size after each overnight run.
SIGNALTUBE_LAB_RENDER_LIMIT=200

# Server2 sync target. The overnight collector pulls the latest DB from Server2
# before collecting, then pushes the updated DB back and triggers a rerender.
SIGNALTUBE_SERVER2_HOST=server2
SIGNALTUBE_SERVER2_DB_PATH=/home/lepton/signaltube-api/data/signaltube.sqlite
SIGNALTUBE_SERVER2_HTML_PATH=/var/www/mavali.top/projects/SignalTube/index.html
SIGNALTUBE_SERVER2_APP_DIR=/home/lepton/signaltube-api
SIGNALTUBE_SERVER2_TITLE=SignalTube
SIGNALTUBE_SERVER2_API_BASE_PATH=/signaltube/api
