# Copy to /etc/default/telegram-aster-trader-bridge and set real values.
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_EXEC_TIMEOUT_SECONDS=36000
TELEGRAM_MAX_INPUT_CHARS=4096
TELEGRAM_MAX_OUTPUT_CHARS=20000
TELEGRAM_RATE_LIMIT_PER_MINUTE=12
TELEGRAM_ASSISTANT_NAME=AsterTrader
TELEGRAM_REQUIRED_PREFIXES=@aster,trade
TELEGRAM_REQUIRED_PREFIX_IGNORE_CASE=true
# Optional state path:
# TELEGRAM_BRIDGE_STATE_DIR=/home/aster-trader/.local/state/telegram-aster-trader-bridge

# ASTER API credentials (required)
ASTER_API_KEY=replace_me
ASTER_API_SECRET=replace_me
ASTER_API_BASE=https://fapi.asterdex.com
ASTER_RECV_WINDOW_MS=5000
ASTER_HTTP_TIMEOUT_SECONDS=15
ASTER_STATE_DB_PATH=/home/aster-trader/.local/state/telegram-aster-trader-bridge/aster_trading.sqlite3

# Risk controls
ASTER_MAX_ORDER_NOTIONAL_USDT=10000
ASTER_NOTIONAL_MAX_OVERSHOOT_PCT=0.15
ASTER_MAX_LEVERAGE=20
ASTER_DAILY_MAX_REALIZED_LOSS_USDT=5000
ASTER_CONFIRM_TTL_SECONDS=120
