# Copy to /etc/default/telegram-trinity-bridge and set real values.
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ASSISTANT_NAME=Trinity
TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false
TELEGRAM_PERSISTENT_WORKERS_ENABLED=true
TELEGRAM_PERSISTENT_WORKERS_MAX=4
TELEGRAM_PERSISTENT_WORKERS_IDLE_TIMEOUT_SECONDS=18000
TELEGRAM_CANONICAL_SESSIONS_ENABLED=true
TELEGRAM_CANONICAL_SQLITE_ENABLED=true
TELEGRAM_CANONICAL_LEGACY_MIRROR_ENABLED=false
TELEGRAM_CANONICAL_JSON_MIRROR_ENABLED=false
TELEGRAM_BRIDGE_STATE_DIR=/var/lib/trinitybot
TELEGRAM_CANONICAL_SQLITE_PATH=/var/lib/trinitybot/chat_sessions.sqlite3
TELEGRAM_MEMORY_SQLITE_PATH=/var/lib/trinitybot/memory.sqlite3
TELEGRAM_AFFECTIVE_RUNTIME_ENABLED=true
TELEGRAM_AFFECTIVE_RUNTIME_DB_PATH=/var/lib/trinitybot/affective_state.sqlite3
TELEGRAM_AFFECTIVE_RUNTIME_PING_TARGET=1.1.1.1
TELEGRAM_POLICY_WATCH_MODE=none
TELEGRAM_RESTART_SCRIPT=/home/architect/matrix/ops/telegram-bridge/restart_and_verify.sh
TELEGRAM_RESTART_UNIT=telegram-trinity-bridge.service

# Optional:
# TELEGRAM_LOG_LEVEL=INFO
# TELEGRAM_API_BASE=https://api.telegram.org
# TELEGRAM_EXEC_TIMEOUT_SECONDS=36000
# TELEGRAM_MAX_INPUT_CHARS=4096
# TELEGRAM_MAX_OUTPUT_CHARS=20000
# TELEGRAM_MAX_IMAGE_BYTES=10485760
# TELEGRAM_MAX_VOICE_BYTES=20971520
# TELEGRAM_MAX_DOCUMENT_BYTES=52428800
# TELEGRAM_RATE_LIMIT_PER_MINUTE=12
# TELEGRAM_POLICY_WATCH_MODE=none
# TELEGRAM_REQUIRED_PREFIXES=@trinity_bot,trinity
# TELEGRAM_REQUIRED_PREFIX_IGNORE_CASE=true
# TELEGRAM_VOICE_TRANSCRIBE_CMD=/home/architect/matrix/ops/telegram-voice/transcribe_voice.sh {file}
# TELEGRAM_VOICE_TRANSCRIBE_TIMEOUT_SECONDS=180
# TELEGRAM_VOICE_ALIAS_LEARNING_ENABLED=true
# TELEGRAM_VOICE_ALIAS_LEARNING_PATH=/var/lib/trinitybot/voice_alias_learning.json
