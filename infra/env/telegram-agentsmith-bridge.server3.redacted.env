TELEGRAM_SELECTABLE_ENGINE_PLUGINS=codex,gemma,pi,venice,chatgptweb
PI_RUNNER=local
PI_MODEL=deepseek-v4-flash
PI_REQUEST_TIMEOUT_SECONDS=600
