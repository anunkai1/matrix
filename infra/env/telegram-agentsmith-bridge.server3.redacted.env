# Redacted mirror of selected live /etc/default/telegram-agentsmith-bridge values on Server3.
# Source path: /etc/default/telegram-agentsmith-bridge
# Secrets are intentionally redacted and must never be committed.

TELEGRAM_BOT_TOKEN=<redacted>
TELEGRAM_ALLOWED_CHAT_IDS=211761499,-5205815348,-1003703507533,-5168463727,-1003730519791
TELEGRAM_ASSISTANT_NAME=AgentSmith
TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false
TELEGRAM_PERSISTENT_WORKERS_ENABLED=false
TELEGRAM_CANONICAL_SESSIONS_ENABLED=false
TELEGRAM_BRIDGE_STATE_DIR=/home/agentsmith/.local/state/telegram-agentsmith-bridge
