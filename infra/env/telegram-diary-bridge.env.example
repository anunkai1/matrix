# Copy to /etc/default/telegram-diary-bridge and set real values.
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ASSISTANT_NAME=Diary
TELEGRAM_SHARED_MEMORY_KEY=shared:diary:main
TELEGRAM_BRIDGE_STATE_DIR=/home/diary/.local/state/telegram-diary-bridge
TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false
TELEGRAM_PERSISTENT_WORKERS_ENABLED=false
TELEGRAM_CANONICAL_SESSIONS_ENABLED=false
TELEGRAM_KEYWORD_ROUTING_ENABLED=false
TELEGRAM_DIARY_MODE_ENABLED=true
TELEGRAM_DIARY_CAPTURE_QUIET_WINDOW_SECONDS=75
TELEGRAM_DIARY_TIMEZONE=Australia/Brisbane
TELEGRAM_DIARY_LOCAL_ROOT=/home/diary/.local/share/diary
TELEGRAM_DIARY_NEXTCLOUD_ENABLED=true
TELEGRAM_DIARY_NEXTCLOUD_BASE_URL=https://nextcloud.example.com
TELEGRAM_DIARY_NEXTCLOUD_USERNAME=DiaryUser
TELEGRAM_DIARY_NEXTCLOUD_APP_PASSWORD=replace_me
TELEGRAM_DIARY_NEXTCLOUD_REMOTE_ROOT=/Diary
TELEGRAM_VOICE_TRANSCRIBE_CMD=/home/architect/matrix/ops/telegram-voice/transcribe_voice.sh {file}
TELEGRAM_VOICE_TRANSCRIBE_TIMEOUT_SECONDS=180
TELEGRAM_VOICE_WHISPER_VENV=/home/diary/.local/share/telegram-voice/venv
TELEGRAM_VOICE_WHISPER_MODEL=medium.en
TELEGRAM_VOICE_WHISPER_SOCKET_PATH=/tmp/telegram-diary-voice-whisper.sock
TELEGRAM_VOICE_WHISPER_LOG_PATH=/home/diary/.local/state/telegram-diary-bridge/telegram-voice-whisper.log
TELEGRAM_RESTART_SCRIPT=/home/architect/matrix/ops/telegram-bridge/restart_and_verify.sh
TELEGRAM_RESTART_UNIT=telegram-diary-bridge.service

# Pi/Venice mirror settings:
# TELEGRAM_SELECTABLE_ENGINE_PLUGINS=codex,gemma,pi
# PI_RUNNER=local
# PI_LOCAL_CWD=/home/diary/diarybot
# PI_REQUEST_TIMEOUT_SECONDS=600
# PI_SESSION_MODE=telegram_scope
# PI_SESSION_DIR=
# PI_SESSION_MAX_BYTES=2097152
# PI_SESSION_MAX_AGE_SECONDS=604800
# PI_SESSION_ARCHIVE_RETENTION_SECONDS=1209600
# PI_SESSION_ARCHIVE_DIR=
# PI_OLLAMA_TUNNEL_ENABLED=false
# PI_OLLAMA_TUNNEL_LOCAL_PORT=11439
# PI_OLLAMA_TUNNEL_REMOTE_HOST=127.0.0.1
# PI_OLLAMA_TUNNEL_REMOTE_PORT=11434
# PI_PROVIDER=venice
# PI_MODEL=deepseek-v4-flash
# VENICE_BASE_URL=https://api.venice.ai/api/v1
# VENICE_MODEL=deepseek-v4-flash
# VENICE_TEMPERATURE=0.2
# VENICE_REQUEST_TIMEOUT_SECONDS=180

# Optional bridge paths:
# TELEGRAM_LOG_LEVEL=INFO
# TELEGRAM_API_BASE=https://api.telegram.org
# TELEGRAM_EXEC_TIMEOUT_SECONDS=36000
# TELEGRAM_MAX_INPUT_CHARS=4096
# TELEGRAM_MAX_OUTPUT_CHARS=20000
# TELEGRAM_MAX_IMAGE_BYTES=10485760
# TELEGRAM_MAX_VOICE_BYTES=20971520
# TELEGRAM_MAX_DOCUMENT_BYTES=52428800
# TELEGRAM_RATE_LIMIT_PER_MINUTE=12
# TELEGRAM_POLICY_WATCH_FILES=/home/diary/diarybot/AGENTS.md
