# Canonical cross-channel routing contract for Govorun on Server3.
# This file defines the expected routing policy across:
# - /etc/default/govorun-whatsapp-bridge
# - /home/govorun/whatsapp-govorun/app/.env

# Canonical chat IDs that must be present in both:
# - TELEGRAM_ALLOWED_CHAT_IDS
# - WA_ALLOWED_CHAT_IDS
CONTRACT_ALLOWED_CHAT_IDS=1434663945,335502052,53072088

# Telegram-side DM/prefix policy.
CONTRACT_TELEGRAM_ALLOW_PRIVATE_CHATS_UNLISTED=true
CONTRACT_TELEGRAM_REQUIRE_PREFIX_IN_PRIVATE=false

# WhatsApp transport-side DM/group policy.
CONTRACT_WA_DM_ALWAYS_RESPOND=true
CONTRACT_WA_GROUP_TRIGGER_REQUIRED=true

# Optional explicit WA CSV allowlists. Keep empty to mean "not enforced by contract".
CONTRACT_WA_ALLOWED_DMS=
CONTRACT_WA_ALLOWED_GROUPS=
